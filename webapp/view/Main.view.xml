<mvc:View
    controllerName="com.reflect.app.controller.Main"
    xmlns="sap.m"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:core="sap.ui.core"
    xmlns:layout="sap.ui.layout"
    xmlns:tnt="sap.tnt"
    xmlns:f="sap.f"
    xmlns:unified="sap.ui.unified"
    height="100%">

    <tnt:ToolPage id="mainToolPage" sideExpanded="{config>/sidebarExpanded}">

        <!-- ═══ Side Navigation ═══ -->
        <tnt:sideContent>
            <tnt:SideNavigation id="sideNav" selectedKey="{config>/activeModeId}">
                <tnt:NavigationList>
                    <tnt:NavigationListItem
                        text="{i18n>sidebarLogo}"
                        icon="sap-icon://home"
                        enabled="false"/>
                </tnt:NavigationList>
            </tnt:SideNavigation>
        </tnt:sideContent>

        <!-- ═══ Main Content ═══ -->
        <tnt:mainContents>
            <Page id="mainPage" showHeader="false" enableScrolling="false">
                <content>
                    <layout:Splitter id="mainSplitter" height="100%">
                        <layout:contentAreas>

                            <!-- ═══ Left Panel: Configuration Sidebar ═══ -->
                            <ScrollContainer
                                id="configPanel"
                                height="100%"
                                vertical="true"
                                horizontal="false">

                                <layout:VerticalLayout class="sapUiSmallMargin" width="100%">

                                    <!-- App Title -->
                                    <Title text="{i18n>sidebarLogo}" level="H3" class="sapUiSmallMarginBottom"/>

                                    <!-- Modules Section -->
                                    <Panel headerText="{i18n>sidebarModulesLabel}" expandable="false" class="sapUiTinyMarginBottom">
                                        <List
                                            id="modulesList"
                                            items="{config>/modes}"
                                            mode="SingleSelectMaster"
                                            selectionChange="onModeChange"
                                            includeItemInSelection="true">
                                            <StandardListItem
                                                title="{config>title}"
                                                description="{config>description}"
                                                icon="{= ${config>icon} === '\u2709\uFE0F' ? 'sap-icon://email' : 'sap-icon://discussion'}"
                                                type="Active"
                                                selected="{= ${config>id} === ${config>/activeModeId}}">
                                                <customData>
                                                    <core:CustomData key="modeId" value="{config>id}"/>
                                                </customData>
                                            </StandardListItem>
                                        </List>
                                    </Panel>

                                    <!-- Configuration Section -->
                                    <Panel headerText="{i18n>sidebarConfigLabel}" expandable="false">
                                        <layout:VerticalLayout width="100%" class="sapUiSmallMargin">

                                            <!-- Relationship -->
                                            <Label text="{i18n>sidebarRelationshipLabel}" labelFor="relationshipInput"/>
                                            <Input
                                                id="relationshipInput"
                                                value="{config>/relationship}"
                                                placeholder="{i18n>sidebarRelationshipPlaceholder}"
                                                width="100%"
                                                class="sapUiTinyMarginBottom"/>

                                            <!-- Situation -->
                                            <Label text="{i18n>sidebarSituationLabel}" labelFor="situationInput"/>
                                            <TextArea
                                                id="situationInput"
                                                value="{config>/situation}"
                                                placeholder="{i18n>sidebarSituationPlaceholder}"
                                                rows="3"
                                                width="100%"
                                                growing="true"
                                                class="sapUiTinyMarginBottom"/>

                                            <!-- Tone Multi-select -->
                                            <Label text="{i18n>sidebarToneLabel}" labelFor="toneSelect"/>
                                            <MultiComboBox
                                                id="toneSelect"
                                                selectedKeys="{config>/selectedTones}"
                                                enabled="{config>/isEmailMode}"
                                                width="100%"
                                                selectionChange="onToneSelectionChange"
                                                class="sapUiTinyMarginBottom">
                                                <core:Item key="Assertive" text="{i18n>toneAssertive}"/>
                                                <core:Item key="Calm" text="{i18n>toneCalm}"/>
                                                <core:Item key="Compassionate" text="{i18n>toneCompassionate}"/>
                                                <core:Item key="Direct" text="{i18n>toneDirect}"/>
                                                <core:Item key="Objective" text="{i18n>toneObjective}"/>
                                                <core:Item key="Pragmatic" text="{i18n>tonePragmatic}"/>
                                                <core:Item key="Reassuring" text="{i18n>toneReassuring}"/>
                                                <core:Item key="Respectful" text="{i18n>toneRespectful}"/>
                                                <core:Item key="Sincere" text="{i18n>toneSincere}"/>
                                                <core:Item key="Thoughtful" text="{i18n>toneThoughtful}"/>
                                            </MultiComboBox>

                                            <!-- Tone Hint (shown when not in email mode) -->
                                            <Text
                                                text="{i18n>sidebarToneHint}"
                                                visible="{= !${config>/isEmailMode}}"
                                                class="sapUiTinyMarginBottom reflect-hint-text"/>

                                            <!-- Model Selection -->
                                            <Label text="{i18n>sidebarModelLabel}" labelFor="modelSelect"/>
                                            <Select
                                                id="modelSelect"
                                                selectedKey="{config>/selectedModel}"
                                                enabled="{= !${config>/modelsLoading}}"
                                                change="onModelChange"
                                                width="100%">
                                            </Select>
                                        </layout:VerticalLayout>
                                    </Panel>

                                </layout:VerticalLayout>
                            </ScrollContainer>

                            <!-- ═══ Right Panel: Chat Area ═══ -->
                            <Page
                                id="chatPage"
                                showNavButton="false"
                                enableScrolling="false">

                                <!-- Chat Header -->
                                <customHeader>
                                    <Bar>
                                        <contentLeft>
                                            <Button
                                                icon="sap-icon://menu2"
                                                type="Transparent"
                                                press="onToggleSidebar"
                                                tooltip="{i18n>headerToggleSidebar}"/>
                                            <Breadcrumbs>
                                                <Link text="{i18n>sidebarLogo}" enabled="false"/>
                                                <Link text="{config>/activeMode/title}" enabled="false"/>
                                            </Breadcrumbs>
                                        </contentLeft>
                                        <contentRight>
                                            <Text
                                                text="{
                                                    path: 'config>/selectedModel',
                                                    formatter: '.formatter.modelDisplayName'
                                                }"
                                                class="reflect-model-label"/>
                                            <Button
                                                text="{i18n>headerClearChat}"
                                                icon="sap-icon://decline"
                                                type="Reject"
                                                press="onClearChat"
                                                visible="{= ${chat>/messages}.length > 0}"/>
                                        </contentRight>
                                    </Bar>
                                </customHeader>

                                <content>
                                    <layout:VerticalLayout width="100%" height="100%" class="reflect-chat-layout">

                                        <!-- Empty State -->
                                        <IllustratedMessage
                                            id="emptyState"
                                            visible="{= ${chat>/messages}.length === 0}"
                                            illustrationType="sapIllus-SimpleBalloon"
                                            title="{= ${config>/activeMode/title} || ${i18n>emptyStateTitle}}"
                                            description="{= ${config>/activeMode/description} || ${i18n>emptyStateDesc}}"
                                            class="reflect-empty-state">
                                            <additionalContent>
                                                <Text text="{
                                                    path: 'config>/selectedModel',
                                                    formatter: '.formatEmptyStateMeta'
                                                }" class="reflect-meta-text"/>
                                            </additionalContent>
                                        </IllustratedMessage>

                                        <!-- Messages List -->
                                        <ScrollContainer
                                            id="messagesScroll"
                                            height="100%"
                                            vertical="true"
                                            horizontal="false"
                                            visible="{= ${chat>/messages}.length > 0}"
                                            class="reflect-messages-scroll">
                                            <List
                                                id="messagesList"
                                                items="{chat>/messages}"
                                                showSeparators="None"
                                                class="reflect-messages-list">
                                                <CustomListItem
                                                    type="Inactive"
                                                    class="{= ${chat>role} === 'user' ? 'reflect-msg-user' : 'reflect-msg-assistant'}">
                                                    <layout:VerticalLayout width="100%" class="sapUiSmallMargin">
                                                        <HBox justifyContent="SpaceBetween" class="sapUiTinyMarginBottom">
                                                            <Text
                                                                text="{
                                                                    path: 'chat>role',
                                                                    formatter: '.formatter.formatRole'
                                                                }"
                                                                class="reflect-role-label"/>
                                                            <Text
                                                                text="{
                                                                    path: 'chat>timestamp',
                                                                    formatter: '.formatter.formatTime'
                                                                }"
                                                                class="reflect-time-label"/>
                                                        </HBox>

                                                        <!-- User message: plain text -->
                                                        <Text
                                                            text="{chat>content}"
                                                            visible="{= ${chat>role} === 'user'}"
                                                            renderWhitespace="true"
                                                            class="reflect-user-text"/>

                                                        <!-- Assistant message: rendered markdown -->
                                                        <core:HTML
                                                            content="{
                                                                path: 'chat>content',
                                                                formatter: '.formatAssistantContent'
                                                            }"
                                                            visible="{= ${chat>role} === 'assistant'}"
                                                            class="reflect-assistant-content"
                                                            sanitizeContent="false"/>

                                                        <!-- Streaming indicator -->
                                                        <HBox
                                                            visible="{chat>isStreaming}"
                                                            alignItems="Center"
                                                            class="reflect-streaming">
                                                            <BusyIndicator size="Small" class="sapUiTinyMarginEnd"/>
                                                            <Text text="{i18n>messageStreaming}" class="reflect-streaming-label"/>
                                                        </HBox>
                                                    </layout:VerticalLayout>
                                                </CustomListItem>
                                            </List>
                                        </ScrollContainer>

                                    </layout:VerticalLayout>
                                </content>

                                <!-- Input Footer -->
                                <footer>
                                    <Toolbar>
                                        <ToolbarSpacer/>
                                        <layout:VerticalLayout width="100%" class="reflect-input-area">
                                            <HBox width="100%" alignItems="End">
                                                <TextArea
                                                    id="chatInput"
                                                    value="{chat>/input}"
                                                    placeholder="{
                                                        path: 'config>/activeMode/title',
                                                        formatter: '.formatInputPlaceholder'
                                                    }"
                                                    rows="1"
                                                    growing="true"
                                                    growingMaxLines="5"
                                                    width="100%"
                                                    liveChange="onInputChange"
                                                    enabled="{= !${chat>/isLoading}}"
                                                    class="reflect-chat-input sapUiTinyMarginEnd"/>
                                                <Button
                                                    id="sendBtn"
                                                    text="{i18n>btnSend}"
                                                    type="Emphasized"
                                                    press="onSendMessage"
                                                    enabled="{= !${chat>/isLoading} &amp;&amp; ${chat>/input}.length > 0}"
                                                    visible="{= !${chat>/isLoading}}"
                                                    class="reflect-send-btn"/>
                                                <Button
                                                    id="stopBtn"
                                                    text="{i18n>btnStop}"
                                                    type="Reject"
                                                    press="onStopStreaming"
                                                    visible="{chat>/isLoading}"
                                                    class="reflect-stop-btn"/>
                                            </HBox>
                                            <HBox justifyContent="SpaceBetween" width="100%" class="sapUiTinyMarginTop">
                                                <Text text="{
                                                    path: 'chat>/input',
                                                    formatter: '.formatCharCount'
                                                }" class="reflect-char-count"/>
                                                <Text text="{i18n>inputHint}" class="reflect-hint-text"/>
                                            </HBox>
                                        </layout:VerticalLayout>
                                        <ToolbarSpacer/>
                                    </Toolbar>
                                </footer>

                            </Page>

                        </layout:contentAreas>
                    </layout:Splitter>
                </content>
            </Page>
        </tnt:mainContents>

    </tnt:ToolPage>

</mvc:View>
