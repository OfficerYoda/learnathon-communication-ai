<mvc:View
    controllerName="com.reflect.app.controller.Main"
    xmlns="sap.m"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:core="sap.ui.core"
    xmlns:layout="sap.ui.layout"
    xmlns:tnt="sap.tnt"
    height="100%">

    <tnt:ToolPage id="mainToolPage" sideExpanded="false">

        <!-- Side Navigation (decorative header only) -->
        <tnt:sideContent>
            <tnt:SideNavigation id="sideNav">
                <tnt:NavigationList>
                    <tnt:NavigationListItem
                        text="{i18n>sidebarLogo}"
                        icon="sap-icon://home"
                        enabled="false"/>
                </tnt:NavigationList>
            </tnt:SideNavigation>
        </tnt:sideContent>

        <!-- Main Content -->
        <tnt:mainContents>
            <Page id="mainPage" showHeader="false" enableScrolling="false">
                <content>
                    <layout:Splitter id="mainSplitter" height="100%">
                        <layout:contentAreas>

                            <!-- Left Panel: Configuration Sidebar -->
                            <ScrollContainer
                                id="configPanel"
                                height="100%"
                                vertical="true"
                                horizontal="false">

                                <layout:VerticalLayout class="sapUiTinyMargin" width="100%">

                                    <Title text="{i18n>sidebarLogo}" level="H3" class="sapUiSmallMarginBottom"/>
                                    <!-- Modes Section -->
                                    <Panel headerText="{i18n>sidebarModesLabel}" expandable="false" class="sapUiTinyMarginBottom">
                                        <List
                                            id="modesList"
                                            items="{config>/modes}"
                                            mode="SingleSelectMaster"
                                            selectionChange="onModeChange"
                                            includeItemInSelection="true">
                                            <StandardListItem
                                                title="{config>title}"
                                                description="{config>description}"
                                                icon="sap-icon://discussion"
                                                type="Active">
                                                <customData>
                                                    <core:CustomData key="modeId" value="{config>id}"/>
                                                </customData>
                                            </StandardListItem>
                                        </List>
                                    </Panel>

                                    <!-- Configuration Section -->
                                    <Panel headerText="{i18n>sidebarConfigLabel}" expandable="false">
                                        <layout:VerticalLayout width="100%">

                                            <Label text="{i18n>sidebarRelationshipLabel}" labelFor="relationshipInput"/>
                                            <Input
                                                id="relationshipInput"
                                                value="{config>/relationship}"
                                                placeholder="{i18n>sidebarRelationshipPlaceholder}"
                                                width="100%"
                                                class="sapUiTinyMarginBottom"/>

                                            <Label text="{i18n>sidebarSituationLabel}" labelFor="situationInput"/>
                                            <TextArea
                                                id="situationInput"
                                                value="{config>/situation}"
                                                placeholder="{i18n>sidebarSituationPlaceholder}"
                                                rows="3"
                                                width="100%"
                                                growing="true"
                                                class="sapUiTinyMarginBottom"/>

                                            <Label text="{i18n>sidebarToneLabel}" labelFor="toneSelect"/>
                                            <MultiComboBox
                                                id="toneSelect"
                                                selectedKeys="{config>/selectedTones}"
                                                enabled="{config>/isEmailMode}"
                                                width="100%"
                                                selectionChange="onToneSelectionChange"
                                                class="sapUiTinyMarginBottom">
                                                <core:Item key="Assertive" text="Assertive"/>
                                                <core:Item key="Calm" text="Calm"/>
                                                <core:Item key="Compassionate" text="Compassionate"/>
                                                <core:Item key="Direct" text="Direct"/>
                                                <core:Item key="Objective" text="Objective"/>
                                                <core:Item key="Pragmatic" text="Pragmatic"/>
                                                <core:Item key="Reassuring" text="Reassuring"/>
                                                <core:Item key="Respectful" text="Respectful"/>
                                                <core:Item key="Sincere" text="Sincere"/>
                                                <core:Item key="Thoughtful" text="Thoughtful"/>
                                            </MultiComboBox>

                                            <Label text="{i18n>sidebarModelLabel}" labelFor="modelSelect"/>
                                            <Select
                                                id="modelSelect"
                                                selectedKey="{config>/selectedModel}"
                                                change="onModelChange"
                                                width="100%">
                                            </Select>
                                        </layout:VerticalLayout>
                                    </Panel>

                                </layout:VerticalLayout>
                            </ScrollContainer>

                            <!-- Right Panel: Chat Area -->
                            <Page
                                id="chatPage"
                                showNavButton="false"
                                enableScrolling="false">

                                <!-- Chat Header -->
                                <customHeader>
                                    <Bar>
                                        <contentLeft>
                                            <Button
                                                icon="sap-icon://menu2"
                                                type="Transparent"
                                                press="onToggleSidebar"
                                                tooltip="{i18n>headerToggleSidebar}"/>
                                            <Title text="{config>/activeMode/title}" level="H5"/>
                                        </contentLeft>
                                        <contentRight>
                                            <Text
                                                text="{
                                                    path: 'config>/selectedModel',
                                                    formatter: '.formatter.modelDisplayName'
                                                }"
                                                class="reflect-model-label"/>
                                            <Button
                                                text="{i18n>headerClearChat}"
                                                icon="sap-icon://decline"
                                                type="Reject"
                                                press="onClearChat"
                                                visible="{= ${chat>/hasMessages} === true}"/>
                                        </contentRight>
                                    </Bar>
                                </customHeader>

                                <content>
                                    <!-- Empty State -->
                                    <VBox
                                        id="emptyState"
                                        visible="{= !${chat>/hasMessages}}"
                                        alignItems="Center"
                                        justifyContent="Center"
                                        height="100%"
                                        class="reflect-empty-state">
                                        <core:Icon src="sap-icon://discussion" size="3rem" color="#bbb" class="sapUiMediumMarginBottom"/>
                                        <Title text="{
                                            path: 'config>/activeMode/title',
                                            formatter: '.formatEmptyTitle'
                                        }" level="H3"/>
                                        <Text text="{
                                            path: 'config>/activeMode/description',
                                            formatter: '.formatEmptyDesc'
                                        }" class="sapUiSmallMarginBottom"/>
                                        <Text text="{
                                            path: 'config>/selectedModel',
                                            formatter: '.formatEmptyStateMeta'
                                        }" class="reflect-meta-text"/>
                                    </VBox>

                                    <!-- Messages List -->
                                    <ScrollContainer
                                        id="messagesScroll"
                                        height="100%"
                                        vertical="true"
                                        horizontal="false"
                                        visible="{chat>/hasMessages}"
                                        class="reflect-messages-scroll">
                                        <List
                                            id="messagesList"
                                            items="{chat>/messages}"
                                            showSeparators="None"
                                            class="reflect-messages-list">
                                            <CustomListItem
                                                type="Inactive"
                                                class="{= ${chat>role} === 'user' ? 'reflect-msg-user' : 'reflect-msg-assistant'}">
                                                <layout:VerticalLayout width="100%" class="sapUiSmallMargin">
                                                    <HBox justifyContent="SpaceBetween" class="sapUiTinyMarginBottom">
                                                        <Text
                                                            text="{
                                                                path: 'chat>role',
                                                                formatter: '.formatter.formatRole'
                                                            }"
                                                            class="reflect-role-label"/>
                                                        <Text
                                                            text="{
                                                                path: 'chat>timestamp',
                                                                formatter: '.formatter.formatTime'
                                                            }"
                                                            class="reflect-time-label"/>
                                                    </HBox>

                                                    <!-- User message: plain text -->
                                                    <Text
                                                        text="{chat>content}"
                                                        visible="{= ${chat>role} === 'user'}"
                                                        renderWhitespace="true"
                                                        class="reflect-user-text"/>

                                                    <!-- Assistant message: rendered markdown -->
                                                    <core:HTML
                                                        content="{chat>contentHtml}"
                                                        visible="{= ${chat>role} === 'assistant'}"
                                                        class="reflect-assistant-content"
                                                        sanitizeContent="false"/>

                                                    <!-- Streaming indicator -->
                                                    <HBox
                                                        visible="{chat>isStreaming}"
                                                        alignItems="Center"
                                                        class="reflect-streaming">
                                                        <BusyIndicator size="1rem" class="sapUiTinyMarginEnd"/>
                                                        <Text text="{i18n>messageStreaming}" class="reflect-streaming-label"/>
                                                    </HBox>
                                                </layout:VerticalLayout>
                                            </CustomListItem>
                                        </List>
                                    </ScrollContainer>
                                </content>

                                <!-- Input Footer -->
                                <footer>
                                    <Toolbar class="reflect-footer-toolbar">
                                        <TextArea
                                            id="chatInput"
                                            value="{chat>/input}"
                                            placeholder="{
                                                path: 'config>/activeMode/title',
                                                formatter: '.formatInputPlaceholder'
                                            }"
                                            rows="1"
                                            growing="true"
                                            growingMaxLines="5"
                                            width="100%"
                                            liveChange="onInputChange"
                                            enabled="{= !${chat>/isLoading}}"
                                            class="reflect-chat-input"/>
                                        <Button
                                            id="sendBtn"
                                            text="{i18n>btnSend}"
                                            type="Emphasized"
                                            press="onSendMessage"
                                            visible="{= !${chat>/isLoading}}"/>
                                        <Button
                                            id="stopBtn"
                                            text="{i18n>btnStop}"
                                            type="Reject"
                                            press="onStopStreaming"
                                            visible="{= ${chat>/isLoading} === true}"/>
                                    </Toolbar>
                                </footer>

                            </Page>

                        </layout:contentAreas>
                    </layout:Splitter>
                </content>
            </Page>
        </tnt:mainContents>

    </tnt:ToolPage>

</mvc:View>
